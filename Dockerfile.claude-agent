# --- Claude Code Agent Environment ---
FROM mcr.microsoft.com/playwright:v1.52.0-noble

# Build tools for native addons + gosu for user switching
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    python3 \
    gosu \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (global) — 版本由 image rebuild 控制，不在容器內自動更新
RUN npm install -g @anthropic-ai/claude-code
ENV DISABLE_AUTOUPDATER=1

# Non-root user (required: --dangerously-skip-permissions blocks root)
RUN useradd -m -s /bin/bash claude

WORKDIR /workspace

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Entrypoint runs as root, drops to claude user via gosu
ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
